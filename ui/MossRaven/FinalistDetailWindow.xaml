<Window x:Class="MossRaven.FinalistDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Build Guide"
        Width="640" Height="720"
        MinWidth="420" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title / one-liner / tags / stats -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TitleText"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="OneLinerText"
                       FontSize="13"
                       Foreground="{DynamicResource DimBrush}"
                       TextWrapping="Wrap" Margin="0,4,0,0"/>
            <TextBlock x:Name="TagsText"
                       FontSize="11"
                       Foreground="{DynamicResource MossBrush}"
                       Margin="0,6,0,0"/>
            <TextBlock x:Name="StatsText"
                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                       Foreground="{DynamicResource TextBrush}"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Guide body -->
        <Border Grid.Row="1" CornerRadius="6"
                Background="{DynamicResource BgBrush}"
                BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel x:Name="GuidePanel"/>
            </ScrollViewer>
        </Border>

        <!-- Actions -->
        <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
            <Button x:Name="CopyCodeButton"
                    DockPanel.Dock="Left"
                    Content="Copy PoB import code"
                    Padding="14,6"
                    Background="{DynamicResource MossBrush}"
                    Foreground="White" BorderThickness="0"
                    Click="CopyCodeButton_Click"/>
            <TextBlock x:Name="CopyHint"
                       DockPanel.Dock="Left"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource DimBrush}"/>
            <Button Content="Close"
                    DockPanel.Dock="Right"
                    Padding="14,6"
                    Background="Transparent"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                    Click="CloseButton_Click"/>
        </DockPanel>
    </Grid>
</Window>
