<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pad + header share one colour -->
    <SolidColorBrush x:Key="BgBrush"           Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TextBrush"         Color="#A4A4A4"/>
    <SolidColorBrush x:Key="DimBrush"          Color="#9A9A9A"/>
    <SolidColorBrush x:Key="DimmerBrush"       Color="#3A3A3A"/>
    <!-- Rainy-day forest moss: deep, muted, slightly cool green — evokes
         wet bark and lichen on a quiet overcast day rather than spring grass. -->
    <SolidColorBrush x:Key="MossBrush"         Color="#2D3A28"/>
    <SolidColorBrush x:Key="HoverBrush"        Color="#2E2E32"/>
    <SolidColorBrush x:Key="CaretBrush"        Color="#7A7A7A"/>
    <SolidColorBrush x:Key="SelectionBrush"    Color="#3A6EA5"/>
    <SolidColorBrush x:Key="PinActiveBrush"    Color="#2A452D"/>
    <SolidColorBrush x:Key="CloseHoverBrush"   Color="#C42B1C"/>
    <SolidColorBrush x:Key="CloseHoverFgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#2E2E2E"/>

</ResourceDictionary>
