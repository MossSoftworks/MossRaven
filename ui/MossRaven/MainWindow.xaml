<Window x:Class="MossRaven.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MossRaven"
        Height="860" Width="1480"
        MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI"
        FontSize="14"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38"
                      ResizeBorderThickness="10"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Aesthetics pass: one place for the card look + type ramp. -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DimmerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="TierHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style x:Key="TierDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource DimBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="TierLog" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MaxHeight" Value="130"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DimmerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Background" Value="{DynamicResource MossBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PrefCombo" TargetType="ComboBox">
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="10"
            Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="180" MinHeight="110"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="{DynamicResource BgBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="MossRaven"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14.5"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="  ·  PoE2 build discovery"
                               Foreground="{DynamicResource DimmerBrush}"
                               FontSize="12.5"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="SettingsButton" Style="{StaticResource TitleBarBtn}"
                            Click="SettingsButton_Click" ToolTip="Settings — per-tier AI models, API keys, paths, ops">
                        <Path Width="16" Height="16" Stretch="Uniform" SnapsToDevicePixels="True"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M9.4 1l.5 2.1c.5.1 1 .3 1.4.6l1.9-1 1.4 1.4-1 1.9c.3.4.5.9.6 1.4l2.1.5v2l-2.1.5c-.1.5-.3 1-.6 1.4l1 1.9-1.4 1.4-1.9-1c-.4.3-.9.5-1.4.6L9.4 17h-2l-.5-2.1c-.5-.1-1-.3-1.4-.6l-1.9 1-1.4-1.4 1-1.9c-.3-.4-.5-.9-.6-1.4L.5 10V8l2.1-.5c.1-.5.3-1 .6-1.4l-1-1.9L3.6 2.8l1.9 1c.4-.3.9-.5 1.4-.6L7.4 1h2zM8.4 6.2a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6z"/>
                    </Button>
                    <Button x:Name="BtnMin" Style="{StaticResource TitleBarBtn}"
                            Click="BtnMin_Click" ToolTip="Minimize">
                        <Path Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 4,8 L 12,8"/>
                    </Button>
                    <Button x:Name="BtnMax" Style="{StaticResource TitleBarBtn}"
                            Click="BtnMax_Click" ToolTip="Maximize">
                        <Path x:Name="MaxIcon"
                              Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 5,3 L 11,3 A 2,2 0 0 1 13,5 L 13,11 A 2,2 0 0 1 11,13 L 5,13 A 2,2 0 0 1 3,11 L 3,5 A 2,2 0 0 1 5,3 Z"/>
                    </Button>
                    <Button x:Name="BtnClose" Style="{StaticResource TitleBarCloseBtn}"
                            Click="BtnClose_Click" ToolTip="Close">
                        <Path Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 3,3 L 13,13 M 13,3 L 3,13"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- MAIN: left Search column | tiers column | Build Workspace (largest) -->
            <Grid Grid.Row="1" Margin="12,8,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" MinWidth="260"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1*" MinWidth="300"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.5*" MinWidth="360"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Search Concept -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10,12,10">
                        <StackPanel>
                            <TextBlock Text="Search concept" Style="{StaticResource PaneTitle}"/>
                            <Border CornerRadius="8"
                                    Background="{DynamicResource BgBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1">
                                <TextBox x:Name="ConceptInput"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="86"
                                         MaxHeight="150"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         CaretBrush="{DynamicResource CaretBrush}"
                                         SelectionBrush="{DynamicResource SelectionBrush}"
                                         BorderThickness="0"
                                         Padding="10,8"
                                         FontSize="15"/>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="SeedButton" Content="Seed" Style="{StaticResource AccentBtn}"
                                        Margin="0,0,6,0" Click="SeedButton_Click"/>
                                <Button x:Name="RunButton" Content="Run 10 gen" Style="{StaticResource GhostBtn}"
                                        Margin="0,0,6,0" Click="RunButton_Click"/>
                                <Button x:Name="HistoryButton" Content="Concepts" Style="{StaticResource GhostBtn}"
                                        ToolTip="Past concepts" Click="HistoryButton_Click"/>
                            </StackPanel>

                            <!-- RETOOL: mode + import code -->
                            <TextBlock Text="Retool a build" Style="{StaticResource PaneTitle}" Margin="0,16,0,6"/>
                            <TextBlock Style="{StaticResource TierDesc}"
                                       Text="Paste a PoB2 import code and pick a focus — the engine re-searches from that build and writes a new guide set."/>
                            <WrapPanel Margin="0,2,0,4">
                                <RadioButton x:Name="RetoolMapping" Content="Mapping" GroupName="RetoolMode"
                                             Foreground="{DynamicResource TextBrush}" Margin="0,0,12,4"/>
                                <RadioButton x:Name="RetoolBossing" Content="Bossing" GroupName="RetoolMode"
                                             Foreground="{DynamicResource TextBrush}" Margin="0,0,12,4"/>
                                <RadioButton x:Name="RetoolBoth" Content="Both" GroupName="RetoolMode" IsChecked="True"
                                             Foreground="{DynamicResource TextBrush}" Margin="0,0,12,4"/>
                                <RadioButton x:Name="RetoolLeveling" Content="Leveling" GroupName="RetoolMode"
                                             Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                            </WrapPanel>
                            <Border CornerRadius="8"
                                    Background="{DynamicResource BgBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1">
                                <TextBox x:Name="RetoolCodeInput"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="56"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         Foreground="{DynamicResource DimBrush}"
                                         CaretBrush="{DynamicResource CaretBrush}"
                                         BorderThickness="0"
                                         Padding="8,6"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="11"
                                         ToolTip="PoB2 import code"/>
                            </Border>
                            <Button x:Name="RetoolButton" Content="Retool" Style="{StaticResource AccentBtn}"
                                    Margin="0,8,0,0" HorizontalAlignment="Left" Click="RetoolButton_Click"/>

                            <!-- PREFERENCES: autofill combos, 5 each -->
                            <TextBlock Text="Preferences (optional)" Style="{StaticResource PaneTitle}" Margin="0,16,0,4"/>
                            <TextBlock Style="{StaticResource TierDesc}"
                                       Text="Steer the search: up to 5 desired uniques, skills, and tree notables. Folded into the hypothesis on Seed."/>
                            <TextBlock Text="Uniques" Foreground="{DynamicResource DimBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,2"/>
                            <StackPanel x:Name="PrefUniquesPanel"/>
                            <TextBlock Text="Skills" Foreground="{DynamicResource DimBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,2"/>
                            <StackPanel x:Name="PrefSkillsPanel"/>
                            <TextBlock Text="Tree notables" Foreground="{DynamicResource DimBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,2"/>
                            <StackPanel x:Name="PrefNodesPanel"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Cursor="SizeWE"/>

                <!-- MIDDLE: tier stack + builds -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Expander Grid.Row="0" x:Name="T1Expander" Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left" Text="Tier 1 — Hypothesis" Style="{StaticResource TierHeader}"/>
                                <TextBlock x:Name="T1HeaderCount" DockPanel.Dock="Right" Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="15" Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TierDesc}"
                                           Text="The dreamer LLM frames your concept into a hypothesis and picks a class-matched seed build (or your text verbatim in Mode B)."/>
                                <TextBox x:Name="T1Log" Style="{StaticResource TierLog}" Text="(no hypotheses yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Grid.Row="1" x:Name="T2Expander" Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left" Text="Tier 2 — Mutations" Style="{StaticResource TierHeader}"/>
                                <TextBlock x:Name="T2HeaderCount" DockPanel.Dock="Right" Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="15" Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TierDesc}"
                                           Text="LLM failover chain (Cerebras → Groq → Gemini) proposes structured mutations — gem levels, swaps, supports, gear, tree, weapon-set flips."/>
                                <TextBox x:Name="T2Log" Style="{StaticResource TierLog}" Text="(no generations yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Grid.Row="2" x:Name="T3ValueExpander" Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left" Text="Tier 3 — Value model" Style="{StaticResource TierHeader}"/>
                                <TextBlock x:Name="T3ValueHeaderCount" DockPanel.Dock="Right" Margin="0,0,8,0"
                                           Foreground="{DynamicResource DimmerBrush}" FontWeight="SemiBold" FontSize="15" Text="pass-through"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TierDesc}"
                                           Text="Learned pre-ranker (gradient-boosted trees) trained on this app's own PoB evaluations. Pass-through until the corpus is big enough — watch the Ops box; every sim grows the training set."/>
                                <TextBox x:Name="T3ValueLog" Style="{StaticResource TierLog}" Text="(not trained yet — corpus accumulating)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Grid.Row="3" x:Name="T3Expander" Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left" Text="Tier 4 — PoB judge" Style="{StaticResource TierHeader}"/>
                                <TextBlock x:Name="T3HeaderCount" DockPanel.Dock="Right" Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="15" Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TierDesc}"
                                           Text="Embedded PoB2 (LuaJIT) scores every variant — DPS, EHP, resists, passive-point legality. The only source of truth; nothing ships un-simmed."/>
                                <TextBox x:Name="T3Log" Style="{StaticResource TierLog}" Text="(no sims yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Grid.Row="4" x:Name="T4Expander" Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left" Text="Tier 5 — Prune" Style="{StaticResource TierHeader}"/>
                                <TextBlock x:Name="T4HeaderCount" DockPanel.Dock="Right" Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="15" Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TierDesc}"
                                           Text="Mechanical gates: passive-point legality (over-budget builds never archived), viability floors, label normalization, interest pruning."/>
                                <TextBox x:Name="T4Log" Style="{StaticResource TierLog}" Text="(no prunings yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Grid.Row="5" x:Name="T6Expander" Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left" Text="Tier 6 — Selector" Style="{StaticResource TierHeader}"/>
                                <TextBlock x:Name="T6HeaderCount" DockPanel.Dock="Right" Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="15" Text="pool = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TierDesc}"
                                           Text="Nominates a pool of 15–20 candidates from the frontier — one-line pitches spanning cost bands and playstyles. Gated against hallucinated ids."/>
                                <TextBox x:Name="T6Log" Style="{StaticResource TierLog}" Text="(no pools yet — run Synthesize)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <Expander Grid.Row="6" x:Name="T7Expander" Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left" Text="Tier 7 — Curator" Style="{StaticResource TierHeader}"/>
                                <TextBlock x:Name="T7HeaderCount" DockPanel.Dock="Right" Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="15" Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="12,8">
                            <StackPanel>
                                <TextBlock Style="{StaticResource TierDesc}"
                                           Text="Picks exactly 5 on value (effectiveness per divine), viability honesty and diversity, then writes the full guides: 5 leveling checkpoints, bossing, mapping, cost notes. Adversarially fact-checked."/>
                                <TextBox x:Name="T7Log" Style="{StaticResource TierLog}" Text="(no curations yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- BUILDS: archive / finalist history list -->
                    <Border Grid.Row="7" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" LastChildFill="False" Margin="14,10,12,4">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Builds" Style="{StaticResource PaneTitle}" Margin="0"/>
                                    <TextBlock Text="Click a build to open it in the workspace →"
                                               Foreground="{DynamicResource DimBrush}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock x:Name="T3CountText" Text="0"
                                               Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="19"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button x:Name="FinalistHistoryButton" Content="History" Style="{StaticResource GhostBtn}"
                                            ToolTip="Browse every saved finalist run"
                                            VerticalAlignment="Center" Margin="0,0,6,0" Click="FinalistHistoryButton_Click"/>
                                    <Button x:Name="SynthesizeFinalistsButton" Content="Synthesize" Style="{StaticResource AccentBtn}"
                                            ToolTip="Tiers 6+7 — pool, curate 5, write guides"
                                            VerticalAlignment="Center" Margin="0,0,6,0" Click="SynthesizeFinalistsButton_Click"/>
                                    <Button x:Name="RefreshArchiveButton" Content="Refresh" Style="{StaticResource GhostBtn}"
                                            VerticalAlignment="Center" Click="RefreshArchiveButton_Click"/>
                                </StackPanel>
                            </DockPanel>

                            <ListBox Grid.Row="1" x:Name="BuildList"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Padding="6,2,6,8">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="6,3"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{DynamicResource DimmerBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="7"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource MossBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <ScrollViewer Grid.Row="1" x:Name="FinalistHistoryScroller"
                                          Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="6,2,6,8">
                                <StackPanel x:Name="FinalistHistoryPanel"/>
                            </ScrollViewer>

                            <TextBlock Grid.Row="2" x:Name="BuildListHint"
                                       Text="Click a build to open it in the workspace."
                                       Foreground="{DynamicResource DimmerBrush}"
                                       FontSize="12"
                                       Margin="14,4,12,10"/>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="3" Width="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Cursor="SizeWE"/>

                <!-- RIGHT: BUILD WORKSPACE (largest) -->
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <Grid Margin="14,10,14,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock x:Name="WsTitle" Text="Build workspace"
                                           Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" FontSize="17"/>
                                <TextBlock x:Name="WsSubtitle" Text="Open a build from the list — view, edit the XML, re-score through PoB, save, or open in desktop PoB2."
                                           Foreground="{DynamicResource DimBrush}" FontSize="12.5" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Grid.Row="1" x:Name="WsStats"
                                   Foreground="{DynamicResource MossBrush}" FontWeight="SemiBold" FontSize="14.5"
                                   Margin="0,8,0,0" TextWrapping="Wrap" Text=""/>
                        <TextBlock Grid.Row="2" x:Name="WsViability"
                                   Foreground="{DynamicResource DimBrush}" FontSize="12.5"
                                   Margin="0,2,0,8" TextWrapping="Wrap" Text=""/>

                        <Border Grid.Row="3" CornerRadius="8"
                                Background="{DynamicResource BgBrush}"
                                BorderBrush="{DynamicResource DimmerBrush}"
                                BorderThickness="1">
                            <TextBox x:Name="WsXml"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource CaretBrush}"
                                     SelectionBrush="{DynamicResource SelectionBrush}"
                                     BorderThickness="0"
                                     Padding="10,8"
                                     FontFamily="Cascadia Mono, Consolas"
                                     FontSize="12"
                                     Text="(no build loaded)"/>
                        </Border>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="WsRescoreButton" Content="Re-score" Style="{StaticResource AccentBtn}"
                                    Margin="0,0,6,0" ToolTip="Run the edited XML through the PoB judge"
                                    Click="WsRescoreButton_Click"/>
                            <Button x:Name="WsSaveButton" Content="Save" Style="{StaticResource GhostBtn}"
                                    Margin="0,0,6,0" ToolTip="Save XML + import code to data\workspace\"
                                    Click="WsSaveButton_Click"/>
                            <Button x:Name="WsCopyCodeButton" Content="Copy code" Style="{StaticResource GhostBtn}"
                                    Margin="0,0,6,0" ToolTip="Copy the PoB2 import code"
                                    Click="WsCopyCodeButton_Click"/>
                            <Button x:Name="WsOpenPobButton" Content="Open in PoB2" Style="{StaticResource GhostBtn}"
                                    ToolTip="Write into PoB2's Builds folder and launch it (set the PoB2 path in Settings)"
                                    Click="WsOpenPobButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="2" Height="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" Cursor="SizeNS" Margin="12,0"/>

            <!-- BOTTOM: Service status (long) + Ops (square-ish) -->
            <Grid Grid.Row="3" Margin="12,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="380" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <DockPanel Margin="12,8,12,8" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="Service status" Style="{StaticResource PaneTitle}"/>
                        <TextBox x:Name="ServiceLog"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent"
                                 Foreground="{DynamicResource DimBrush}"
                                 BorderThickness="0"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="12"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <Grid Margin="12,8,12,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Ops" Style="{StaticResource PaneTitle}"/>
                        <DockPanel Grid.Row="1" Margin="0,2,0,4" LastChildFill="True">
                            <Button x:Name="OpsChurnButton" DockPanel.Dock="Right" Content="Start" Style="{StaticResource GhostBtn}"
                                    Padding="10,2" Click="OpsChurnButton_Click"
                                    ToolTip="Overnight corpus growth (scripts\corpus-churn.ps1) — grows the Tier-3 training set"/>
                            <TextBlock x:Name="OpsChurnStatus" Text="Corpus churn — idle · 0 rows"
                                       Foreground="{DynamicResource DimBrush}" FontSize="12.5" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                        <DockPanel Grid.Row="2" Margin="0,0,0,4" LastChildFill="True">
                            <Button x:Name="OpsRescoreButton" DockPanel.Dock="Right" Content="Run" Style="{StaticResource GhostBtn}"
                                    Padding="10,2" Click="OpsRescoreButton_Click"
                                    ToolTip="Re-run PoB on every archive elite (run after each league patch / vendor pull)"/>
                            <TextBlock x:Name="OpsRescoreStatus" Text="Rescore archive — idle"
                                       Foreground="{DynamicResource DimBrush}" FontSize="12.5" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                        <DockPanel Grid.Row="3" LastChildFill="True">
                            <Button x:Name="OpsTrainButton" DockPanel.Dock="Right" Content="Train" Style="{StaticResource GhostBtn}"
                                    Padding="10,2" Click="OpsTrainButton_Click"
                                    ToolTip="Train the Tier-3 value model (needs Python + pip install lightgbm scikit-learn scipy; ≥5k corpus rows)"/>
                            <TextBlock x:Name="OpsTrainStatus" Text="Value model — not trained"
                                       Foreground="{DynamicResource DimBrush}" FontSize="12.5" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status strip -->
            <Border Grid.Row="4" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <TextBlock x:Name="ServiceStateText"
                               Text="service: disconnected"
                               Foreground="{DynamicResource DimBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="MossRaven v0.2"
                               Foreground="{DynamicResource DimmerBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,12,0"
                               FontSize="12"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
