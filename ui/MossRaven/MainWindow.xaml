<Window x:Class="MossRaven.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MossRaven"
        Height="720" Width="1200"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Grayscale">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            CornerRadius="8"
            Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="{DynamicResource BgBrush}">
                <TextBlock Text="MossRaven"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           Foreground="{DynamicResource DimBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="BtnMin" Style="{StaticResource TitleBarBtn}"
                            Click="BtnMin_Click" ToolTip="Minimize">
                        <Path Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 4,8 L 12,8"/>
                    </Button>
                    <Button x:Name="BtnMax" Style="{StaticResource TitleBarBtn}"
                            Click="BtnMax_Click" ToolTip="Maximize">
                        <Path x:Name="MaxIcon"
                              Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 5,3 L 11,3 A 2,2 0 0 1 13,5 L 13,11 A 2,2 0 0 1 11,13 L 5,13 A 2,2 0 0 1 3,11 L 3,5 A 2,2 0 0 1 5,3 Z"/>
                    </Button>
                    <Button x:Name="BtnClose" Style="{StaticResource TitleBarCloseBtn}"
                            Click="BtnClose_Click" ToolTip="Close">
                        <Path Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 3,3 L 13,13 M 13,3 L 3,13"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content: 3-col layout. Center column is a fat draggable splitter. -->
            <Grid Grid.Row="1" Background="{DynamicResource BgBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" MinWidth="220"/>
                    <ColumnDefinition Width="10"/>  <!-- vertical splitter — fatter for easier grab -->
                    <ColumnDefinition Width="*" MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANE: top group (concept+buttons) / horizontal splitter / bottom group (service log) -->
                <Grid Grid.Column="0" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="180"/>   <!-- concept group -->
                        <RowDefinition Height="10"/>                  <!-- horizontal splitter -->
                        <RowDefinition Height="*" MinHeight="80"/>    <!-- service log group -->
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Search concept"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="SeedButton"
                                    Content="Seed hypothesis"
                                    Padding="12,5"
                                    Margin="0,0,6,0"
                                    Background="{DynamicResource MossBrush}"
                                    Foreground="{DynamicResource CloseHoverFgBrush}"
                                    BorderThickness="0"
                                    Click="SeedButton_Click"/>
                            <Button x:Name="RunButton"
                                    Content="Run 10 gen"
                                    Padding="12,5"
                                    Margin="0,0,6,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1"
                                    Click="RunButton_Click"/>
                            <Button x:Name="HistoryButton"
                                    Content="History"
                                    Padding="10,5"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1"
                                    ToolTip="Past concepts"
                                    Click="HistoryButton_Click"/>
                        </StackPanel>
                        <Border CornerRadius="6"
                                Background="{DynamicResource BgBrush}"
                                BorderBrush="{DynamicResource DimmerBrush}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <TextBox x:Name="ConceptInput"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource CaretBrush}"
                                     SelectionBrush="{DynamicResource SelectionBrush}"
                                     BorderThickness="0"
                                     Padding="10,8"
                                     FontFamily="Segoe UI Variable Text, Segoe UI, Calibri"
                                     FontSize="15"
                                     FontWeight="Regular"
                                     TextOptions.TextFormattingMode="Ideal"
                                     TextOptions.TextRenderingMode="ClearType"/>
                        </Border>
                    </DockPanel>

                    <!-- Horizontal splitter between concept group and service log. Tall grab zone. -->
                    <GridSplitter Grid.Row="1"
                                  Height="10"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"
                                  ResizeDirection="Rows"
                                  Cursor="SizeNS"/>

                    <DockPanel Grid.Row="2" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Service status"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Border CornerRadius="6"
                                Background="{DynamicResource BgBrush}"
                                BorderBrush="{DynamicResource DimmerBrush}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <TextBox x:Name="ServiceLog"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     Foreground="{DynamicResource DimBrush}"
                                     BorderThickness="0"
                                     FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
                                     FontSize="12"
                                     Padding="8,6"/>
                        </Border>
                    </DockPanel>
                </Grid>

                <!-- Vertical splitter between left/right column. Fatter than the default. -->
                <GridSplitter Grid.Column="1"
                              Width="10"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns"
                              Cursor="SizeWE"/>

                <Border Grid.Column="2" Margin="0,12,12,12"
                        CornerRadius="6"
                        Background="{DynamicResource BgBrush}"
                        BorderBrush="{DynamicResource DimmerBrush}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Background="{DynamicResource BgBrush}" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="MAP-Elites archive"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="12,8,0,8"/>
                            <TextBlock x:Name="ArchiveSummary"
                                       DockPanel.Dock="Right"
                                       Text="empty"
                                       Foreground="{DynamicResource DimBrush}"
                                       Margin="0,8,12,8"/>
                            <Button x:Name="RefreshArchiveButton"
                                    DockPanel.Dock="Right"
                                    Content="Refresh"
                                    Padding="10,3"
                                    Margin="0,4,8,4"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1"
                                    Click="RefreshArchiveButton_Click"/>
                        </DockPanel>
                        <TextBox Grid.Row="1"
                                 x:Name="ArchiveView"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderThickness="0"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="12"
                                 Padding="12,4"
                                 Text="(empty — click Seed then Run to populate)"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status strip -->
            <Border Grid.Row="2" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <TextBlock x:Name="ServiceStateText"
                               Text="service: disconnected"
                               Foreground="{DynamicResource DimBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="11"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="MossRaven v0.1.0 (scaffold)"
                               Foreground="{DynamicResource DimmerBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,12,0"
                               FontSize="11"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
