<Window x:Class="MossRaven.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MossRaven"
        Height="720" Width="1200"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Grayscale">

    <WindowChrome.WindowChrome>
        <!-- ResizeBorderThickness=10 (was 5) — matches MossPage canonical pattern;
             fatter grab zone for less-precise edge dragging. WPF content owns the
             whole window area so resize fires anywhere within 10px of any edge. -->
        <WindowChrome CaptionHeight="36"
                      ResizeBorderThickness="10"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            CornerRadius="8"
            Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="{DynamicResource BgBrush}">
                <TextBlock Text="MossRaven"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           Foreground="{DynamicResource DimBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="BtnMin" Style="{StaticResource TitleBarBtn}"
                            Click="BtnMin_Click" ToolTip="Minimize">
                        <Path Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 4,8 L 12,8"/>
                    </Button>
                    <Button x:Name="BtnMax" Style="{StaticResource TitleBarBtn}"
                            Click="BtnMax_Click" ToolTip="Maximize">
                        <Path x:Name="MaxIcon"
                              Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 5,3 L 11,3 A 2,2 0 0 1 13,5 L 13,11 A 2,2 0 0 1 11,13 L 5,13 A 2,2 0 0 1 3,11 L 3,5 A 2,2 0 0 1 5,3 Z"/>
                    </Button>
                    <Button x:Name="BtnClose" Style="{StaticResource TitleBarCloseBtn}"
                            Click="BtnClose_Click" ToolTip="Close">
                        <Path Width="16" Height="16" Stretch="None" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.25"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="M 3,3 L 13,13 M 13,3 L 3,13"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Content: 3-col layout. Center column is a fat draggable splitter. -->
            <Grid Grid.Row="1" Background="{DynamicResource BgBrush}">
                <Grid.ColumnDefinitions>
                    <!-- Star-sized so both panes scale proportionally with the window.
                         Left starts at ~33% of width (1*), right at ~67% (2*). The
                         splitter at column 1 lets the user override the ratio; once
                         dragged, it becomes a fixed-pixel column until the user
                         drags again. MinWidth keeps each pane usable on narrow
                         windows. Previously column 0 was Width="360" (hardcoded
                         pixels) — the left pane never grew when the user resized
                         the window, leaving wasted space on wide monitors. -->
                    <ColumnDefinition Width="1*" MinWidth="220"/>
                    <ColumnDefinition Width="10"/>  <!-- vertical splitter — fatter for easier grab -->
                    <ColumnDefinition Width="2*" MinWidth="320"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANE: top group (concept+buttons) / horizontal splitter / bottom group (service log) -->
                <Grid Grid.Column="0" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="180"/>   <!-- concept group -->
                        <RowDefinition Height="10"/>                  <!-- horizontal splitter -->
                        <RowDefinition Height="*" MinHeight="80"/>    <!-- service log group -->
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Search concept"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="SeedButton"
                                    Content="Seed hypothesis"
                                    Padding="12,5"
                                    Margin="0,0,6,0"
                                    Background="{DynamicResource MossBrush}"
                                    Foreground="{DynamicResource CloseHoverFgBrush}"
                                    BorderThickness="0"
                                    Click="SeedButton_Click"/>
                            <Button x:Name="RunButton"
                                    Content="Run 10 gen"
                                    Padding="12,5"
                                    Margin="0,0,6,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1"
                                    Click="RunButton_Click"/>
                            <Button x:Name="HistoryButton"
                                    Content="History"
                                    Padding="10,5"
                                    Margin="0,0,6,0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1"
                                    ToolTip="Past concepts"
                                    Click="HistoryButton_Click"/>
                            <Button x:Name="ModelSettingsButton"
                                    Content="Models"
                                    Padding="10,5"
                                    Background="Transparent"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource DimmerBrush}"
                                    BorderThickness="1"
                                    ToolTip="Choose which LLM drives each tier; add/remove provider API keys"
                                    Click="ModelSettingsButton_Click"/>
                        </StackPanel>
                        <Border CornerRadius="6"
                                Background="{DynamicResource BgBrush}"
                                BorderBrush="{DynamicResource DimmerBrush}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <TextBox x:Name="ConceptInput"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     CaretBrush="{DynamicResource CaretBrush}"
                                     SelectionBrush="{DynamicResource SelectionBrush}"
                                     BorderThickness="0"
                                     Padding="10,8"
                                     FontFamily="Segoe UI Variable Text, Segoe UI, Calibri"
                                     FontSize="15"
                                     FontWeight="Regular"
                                     TextOptions.TextFormattingMode="Ideal"
                                     TextOptions.TextRenderingMode="ClearType"/>
                        </Border>
                    </DockPanel>

                    <!-- Horizontal splitter between concept group and service log. Tall grab zone. -->
                    <GridSplitter Grid.Row="1"
                                  Height="10"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"
                                  ResizeDirection="Rows"
                                  Cursor="SizeNS"/>

                    <DockPanel Grid.Row="2" LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Service status"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <Border CornerRadius="6"
                                Background="{DynamicResource BgBrush}"
                                BorderBrush="{DynamicResource DimmerBrush}"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <TextBox x:Name="ServiceLog"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Background="Transparent"
                                     Foreground="{DynamicResource DimBrush}"
                                     BorderThickness="0"
                                     FontFamily="Segoe UI Variable Text, Segoe UI, Segoe UI Emoji"
                                     FontSize="12"
                                     Padding="8,6"/>
                        </Border>
                    </DockPanel>
                </Grid>

                <!-- Vertical splitter between left/right column. Fatter than the default. -->
                <GridSplitter Grid.Column="1"
                              Width="10"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns"
                              Cursor="SizeWE"/>

                <!-- Right pane: 5 stacked boxes (the user-facing tier model).
                     Tiers 1-4 are Expanders (click header to expand log).
                     The finalists pane is always expanded (it's the output the user works with). -->
                <Grid Grid.Column="2" Margin="0,12,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TIER 1: Hypothesis (Claude / Mode B Claude Code) -->
                    <Expander Grid.Row="0"
                              x:Name="T1Expander"
                              Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}"
                              BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <!-- HorizontalAlignment=Stretch lets the header fill the Expander's
                                 actual width, so resizing the right column shrinks/grows the
                                 header instead of clipping at a fixed 270px. -->
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Tier 1 — Hypothesis"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="T1HeaderCount"
                                           DockPanel.Dock="Right"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}"
                                           FontWeight="SemiBold"
                                           Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="Tier-1 LLM (Claude / Gemini / Groq — or your concept verbatim in Mode B) frames the hypothesis and picks a class-matched seed build."
                                           Foreground="{DynamicResource DimBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="T1Log"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="11"
                                         Text="(no hypotheses yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- TIER 2: Mutation proposals (LLM — Claude for quality OR Cerebras for volume) -->
                    <Expander Grid.Row="1"
                              x:Name="T2Expander"
                              Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}"
                              BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <!-- HorizontalAlignment=Stretch lets the header fill the Expander's
                                 actual width, so resizing the right column shrinks/grows the
                                 header instead of clipping at a fixed 270px. -->
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Tier 2 — Mutations proposed"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="T2HeaderCount"
                                           DockPanel.Dock="Right"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}"
                                           FontWeight="SemiBold"
                                           Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="LLM failover chain (Cerebras → Groq → Gemini) proposes 10 structured mutations per generation — gem levels, swaps, support add/remove, weapon-set flips."
                                           Foreground="{DynamicResource DimBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="T2Log"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="11"
                                         Text="(no generations yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- TIER 3: PoB sims (deterministic, just numbers) -->
                    <Expander Grid.Row="2"
                              x:Name="T3Expander"
                              Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}"
                              BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <!-- HorizontalAlignment=Stretch lets the header fill the Expander's
                                 actual width, so resizing the right column shrinks/grows the
                                 header instead of clipping at a fixed 270px. -->
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Tier 4 — PoB sims (judge)"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="T3HeaderCount"
                                           DockPanel.Dock="Right"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}"
                                           FontWeight="SemiBold"
                                           Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="Embedded PoB2 (LuaJIT) scores every variant — DPS/EHP/resists, stamped with the live PoB2 data version. Single source of truth."
                                           Foreground="{DynamicResource DimBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="T3Log"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="11"
                                         Text="(no sims yet)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- TIER 4: Pruning by interest/novelty (LLM — Cerebras fine here, easier judgment task) -->
                    <Expander Grid.Row="3"
                              x:Name="T4Expander"
                              Margin="0,0,0,6"
                              Background="{DynamicResource BgBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource DimmerBrush}"
                              BorderThickness="1"
                              HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <!-- HorizontalAlignment=Stretch lets the header fill the Expander's
                                 actual width, so resizing the right column shrinks/grows the
                                 header instead of clipping at a fixed 270px. -->
                            <DockPanel LastChildFill="False" HorizontalAlignment="Stretch" MinWidth="240">
                                <TextBlock DockPanel.Dock="Left"
                                           Text="Tier 5 — Pruned (legality + interest)"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="T4HeaderCount"
                                           DockPanel.Dock="Right"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource MossBrush}"
                                           FontWeight="SemiBold"
                                           Text="n = 0"/>
                            </DockPanel>
                        </Expander.Header>
                        <Border Background="{DynamicResource BgBrush}" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="Pre-sim prune: the Tier-2 LLM cheap-scores interest + plausibility before PoB time is spent. Post-sim smart pruning is on the roadmap."
                                           Foreground="{DynamicResource DimBrush}"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <TextBox x:Name="T4Log"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Mono, Consolas"
                                         FontSize="11"
                                         Text="(no prunings yet — pre-sim pruning only; post-sim viability gating is on the roadmap)"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- TIER 5: Finalists — always expanded, clickable copy-to-clipboard cards -->
                    <Border Grid.Row="4"
                            CornerRadius="6"
                            Background="{DynamicResource BgBrush}"
                            BorderBrush="{DynamicResource DimmerBrush}"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" LastChildFill="False" Margin="14,10,12,4">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Tiers 6+7 — Finalists"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="13"/>
                                    <TextBlock Text="Curated builds with full guides. Click = copy PoB code · History = every saved run."
                                               Foreground="{DynamicResource DimBrush}"
                                               FontSize="11"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock x:Name="T3CountText"
                                               Text="0"
                                               Foreground="{DynamicResource MossBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <Button x:Name="FinalistHistoryButton"
                                            Content="History"
                                            ToolTip="Browse every saved finalist run — click a build for its full guide"
                                            VerticalAlignment="Center"
                                            Padding="10,3"
                                            Margin="0,0,6,0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextBrush}"
                                            BorderBrush="{DynamicResource DimmerBrush}"
                                            BorderThickness="1"
                                            Click="FinalistHistoryButton_Click"/>
                                    <Button x:Name="SynthesizeFinalistsButton"
                                            Content="Synthesize"
                                            ToolTip="Tiers 6+7 — select a pool, curate 5 builds, write full guides"
                                            VerticalAlignment="Center"
                                            Padding="10,3"
                                            Margin="0,0,6,0"
                                            Background="{DynamicResource MossBrush}"
                                            Foreground="White"
                                            BorderBrush="{DynamicResource MossBrush}"
                                            BorderThickness="1"
                                            Click="SynthesizeFinalistsButton_Click"/>
                                    <Button x:Name="RefreshArchiveButton"
                                            Content="Refresh"
                                            VerticalAlignment="Center"
                                            Padding="10,3"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextBrush}"
                                            BorderBrush="{DynamicResource DimmerBrush}"
                                            BorderThickness="1"
                                            Click="RefreshArchiveButton_Click"/>
                                </StackPanel>
                            </DockPanel>

                            <ListBox Grid.Row="1"
                                     x:Name="BuildList"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     Padding="6,2,6,8">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin" Value="6,3"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="bd"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{DynamicResource DimmerBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="5"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource MossBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <!-- FINALIST HISTORY: every saved finalists/<ts>/ run, newest
                                 first, one Expander per run. Swapped with BuildList by
                                 the History toggle. Items are built in code-behind
                                 (LoadFinalistHistory) from finalists.json files. -->
                            <ScrollViewer Grid.Row="1"
                                          x:Name="FinalistHistoryScroller"
                                          Visibility="Collapsed"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="6,2,6,8">
                                <StackPanel x:Name="FinalistHistoryPanel"/>
                            </ScrollViewer>

                            <TextBlock Grid.Row="2"
                                       x:Name="BuildListHint"
                                       Text="Click a build to copy its PoB import code to clipboard."
                                       Foreground="{DynamicResource DimmerBrush}"
                                       FontSize="11"
                                       Margin="14,4,12,10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- Status strip -->
            <Border Grid.Row="2" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource DimmerBrush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <TextBlock x:Name="ServiceStateText"
                               Text="service: disconnected"
                               Foreground="{DynamicResource DimBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="11"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="MossRaven v0.1.0 (scaffold)"
                               Foreground="{DynamicResource DimmerBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,12,0"
                               FontSize="11"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
